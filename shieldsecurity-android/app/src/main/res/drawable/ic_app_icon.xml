<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#071320" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item android:left="12dp" android:top="12dp" android:right="12dp" android:bottom="12dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#79D0FF"
                android:centerColor="#4A7DFF"
                android:endColor="#7B5CFF"
                android:angle="315" />
        </shape>
    </item>
    <item android:left="26dp" android:top="20dp" android:right="26dp" android:bottom="26dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <stroke
                android:width="3dp"
                android:color="#FFFFFFFF" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <item android:left="40dp" android:top="28dp" android:right="40dp" android:bottom="38dp">
        <shape android:shape="rectangle">
            <corners android:radius="5dp" />
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>
</layer-list>
